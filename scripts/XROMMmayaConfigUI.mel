global proc XROMMmayaConfigUI(){	if (`window -exists XROMMmayaConfigUIWindow` == true) deleteUI XROMMmayaConfigUIWindow;  	int $height = 200;	int $width = 340;	int $cw = 110;	string $mainWindow = `window -title "Recommended maya config parameters" -menuBar true		-maximizeButton false -minimizeButton true -sizeable false -resizeToFitChildren true		XROMMmayaConfigUIWindow`;	columnLayout -co "left" 0 -rs 5 xconCL1;		rowLayout -nc 3 -gsp 5 -cw3 $cw $cw $cw xconRL1;			text -l ""; text -l ""; text "Recommended";		setParent..;		columnLayout -co "left" 10 -rs 5 xconCL2;			// get up axis and select correct one			radioButtonGrp -nrb 2 -label "Up axis" -labelArray2 "y" "z" 			-cat 1 "left" 0 -cw3 $cw $cw $cw -cc upAxCC upAxRBGrp;   			string $up = `upAxis -q -ax`;			if ($up == "y"){radioButtonGrp -e -sl 1 upAxRBGrp;}			else if ($up == "z"){radioButtonGrp -e -sl 2 upAxRBGrp;}						// tumble context			radioButtonGrp -nrb 2 -label "Tumble context" -labelArray2 "on object false" "on object true" 				-cw3 $cw $cw $cw  -cat 1 "left" 0 -cc tumbleCC tumbleRBGrp;			if (`tumbleCtx -q -objectTumble tumbleContext`){radioButtonGrp -e -sl 2 tumbleRBGrp;}			else {radioButtonGrp -e -sl 1 tumbleRBGrp;}						// ViewCube			int $version = `about -version`;			if ($version < 2017)			{				radioButtonGrp -nrb 2 -label "View cube (only with legacy viewport)" -labelArray2 "on" "off" 					-cw3 $cw $cw $cw  -cat 1 "left" 0 -cc viewCubeCC viewCubeRBGrp;				if (`viewManip -q -visible`){radioButtonGrp -e -sl 1 viewCubeRBGrp;}				else {radioButtonGrp -e -sl 2 viewCubeRBGrp;}			}						//change to background color to to remove gradient			radioButtonGrp -nrb 2 -label "Background gradient" -labelArray2 "on" "off" 				-cw3 $cw $cw $cw  -cat 1 "left" 0 -cc gradientCC gradientRBGrp;			if (`displayPref -q -displayGradient`){radioButtonGrp -e -sl 1 gradientRBGrp;}			else {radioButtonGrp -e -sl 2 gradientRBGrp;}					//set Playback to all cameras, continuous looping			radioButtonGrp -nrb 2 -label "Playback views" -labelArray2 "active" "all" 				-cw3 $cw $cw $cw  -cat 1 "left" 0 -cc playbackViewsCC playbackViewsRBGrp;			string $pbViews = `playbackOptions -q -v`;			if ($pbViews == "active"){radioButtonGrp -e -sl 1 playbackViewsRBGrp;}			else if ($pbViews == "all"){radioButtonGrp -e -sl 2 playbackViewsRBGrp;}						// playback looping			radioButtonGrp -nrb 2 -label "Playback looping" -labelArray2 "once" "continuous" 				-cw3 $cw $cw $cw  -cat 1 "left" 0 -cc playbackLoopCC playbackLoopRBGrp;			string $pbLoops = `playbackOptions -q -loop`;			if ($pbLoops == "once"){radioButtonGrp -e -sl 1 playbackLoopRBGrp;}			else if ($pbLoops == "continuous"){radioButtonGrp -e -sl 2 playbackLoopRBGrp;}					//set Maya to native operating system dialog interface			radioButtonGrp -nrb 2 -label "File dialog style" -labelArray2 "maya" "os native" 				-cw3 $cw $cw $cw  -cat 1 "left" 0 -cc fileDialogCC fileDialogRBGrp;			int $fds = `optionVar -q FileDialogStyle`;			if ($fds == 2){radioButtonGrp -e -sl 1 fileDialogRBGrp;}			else if ($fds == 1){radioButtonGrp -e -sl 2 fileDialogRBGrp;}						// if the icon bars are visible (collapseIconBarsInPanels = 0),  turn them off			radioButtonGrp -nrb 2 -label "Icon bars" -labelArray2 "visible" "hidden" 				-cw3 $cw $cw $cw  -cat 1 "left" 0 -cc iconBarsCC iconBarsRBGrp;			int $collapseIcon = `optionVar -q collapseIconBarsInPanels`;			if ($collapseIcon == 0){radioButtonGrp -e -sl 1 iconBarsRBGrp;}			else if ($collapseIcon == 1){radioButtonGrp -e -sl 2 iconBarsRBGrp;}		setParent..;		rowLayout -nc 3 -gsp 5 -cw3 $cw $cw $cw xconRL2;			text -l "";			button -l "Move ALL Left" -c xconMvLeftCmd xconMvLeftBtn;			button -l "Move ALL Right" -c xconMvRightCmd xconMvRightBtn;		setParent..;		    setParent..;	showWindow $mainWindow;	window -e -width $width $mainWindow;}global proc upAxCC(){    if (`radioButtonGrp -q -sl upAxRBGrp` == 1){setUpAxis "y";}    if (`radioButtonGrp -q -sl upAxRBGrp` == 2){setUpAxis "z";}}global proc tumbleCC(){    if (`radioButtonGrp -q -sl tumbleRBGrp` == 1){tumbleCtx -e -objectTumble 0 tumbleContext;}    if (`radioButtonGrp -q -sl tumbleRBGrp` == 2){tumbleCtx -e -objectTumble 1 tumbleContext;}}global proc viewCubeCC(){    if (`radioButtonGrp -q -sl viewCubeRBGrp` == 1){viewManip -visible 1;}    if (`radioButtonGrp -q -sl viewCubeRBGrp` == 2){viewManip -visible 0;}}global proc gradientCC(){    if (`radioButtonGrp -q -sl gradientRBGrp` == 1){displayPref -displayGradient 1;refresh;}    if (`radioButtonGrp -q -sl gradientRBGrp` == 2){displayPref -displayGradient 0;refresh;}}global proc playbackViewsCC(){    if (`radioButtonGrp -q -sl playbackViewsRBGrp` == 1){playbackOptions -e -v "active";}    if (`radioButtonGrp -q -sl playbackViewsRBGrp` == 2){playbackOptions  -e -v "all";}}global proc playbackLoopCC(){    if (`radioButtonGrp -q -sl playbackLoopRBGrp` == 1){playbackOptions -e -loop "once";}    if (`radioButtonGrp -q -sl playbackLoopRBGrp` == 2){playbackOptions  -e -loop "continuous";}}global proc fileDialogCC(){    if (`radioButtonGrp -q -sl fileDialogRBGrp` == 1){optionVar -iv FileDialogStyle 2;}    if (`radioButtonGrp -q -sl fileDialogRBGrp` == 2){optionVar -iv FileDialogStyle 1;}}global proc iconBarsCC(){    if (`radioButtonGrp -q -sl iconBarsRBGrp` == 1)    {    	if (`optionVar -q collapseIconBarsInPanels`) {toggleModelEditorBarsInAllPanels 1;} else {toggleModelEditorBarsInAllPanels 0;};    	optionVar -iv collapseIconBarsInPanels 0;    }                if (`radioButtonGrp -q -sl iconBarsRBGrp` == 2)    {    	if (!`optionVar -q collapseIconBarsInPanels`) {toggleModelEditorBarsInAllPanels 0;} else {toggleModelEditorBarsInAllPanels 1;};    	optionVar -iv collapseIconBarsInPanels 1;    }}global proc xconMvLeftCmd(){	//for each radiobutton control choose sl 1	string $rbgs[] = `layout -q -ca xconCL2`; 	for($r in $rbgs)	{		radioButtonGrp -e -sl 1 $r;		$r = substituteAllString($r,"RBGrp","CC");		eval($r+";");	}	}global proc xconMvRightCmd(){	string $rbgs[] = `layout -q -ca xconCL2`; 	for($r in $rbgs)	{		radioButtonGrp -e -sl 2 $r;		$r = substituteAllString($r,"RBGrp","CC");		eval($r+";");	}}