/*global proc animPanScan()	Modification of willPanAndScanMel.mel	for manipulation of locked camera during rotoscoping	removed some features to simplify	changed because Dave's xcam script already includes Shape node naming	index finger for overscan (zoom) and middle for offset (pan)	Original modification by S. Gatesy		5/23/2014 - changed transparency tool. now starts with default shader	separate shelf button to change shader affected by transparency. D. Baier		7/27/2016 - Adjusted for latest version of xcam where cameras are no	longer changed to the camera shape node in the panel list. D. Baier	*/global proc animPanScan()	{	string $gvars[] = `env`;	if (!stringArrayContains("$gPanScanShader", $gvars))	{global string $gPanScanShader = "lambert1";}	    if(!`draggerContext -q -exists panandtrackContext`)    {    draggerContext -pressCommand "float $ovshfavfa[] = getOverscan();" 		-dragCommand  "panandtrackDrag($ovshfavfa[0], $ovshfavfa[1], $ovshfavfa[2], $ovshfavfa[3], $ovshfavfa[4])"		-cursor "hand" 		-sp "screen" 		-pr "viewPlane"		panandtrackContext;	}	setToolTo panandtrackContext;}global proc float[] getOverscan()	{	// get shader	//if (`window -exists apssWindow` == false) animPanScanShader;	//string $shader = `textFieldGrp -q -text apssGroup`; 	global string $gPanScanShader;	string $shader = $gPanScanShader;	string $getMod = `draggerContext -query -mo panandtrackContext`;	int    $button = `draggerContext -query -button panandtrackContext`;	string $cPanel = `getPanel -withFocus`;	string $cCamera = `modelPanel -q -cam $cPanel`;	string $cCameraShape = $cCamera;	// adjusted for backward compatability 6/27/2016 Baier	if (`nodeType $cCamera` == "transform")		{			string $tmpShape[] = `listRelatives -s -ni $cCamera`;			$cCameraShape = $tmpShape[0];		}	float $returnArray[];	$returnArray[0] = `getAttr ($cCameraShape + ".overscan")`;	$returnArray[1] = `getAttr ($cCameraShape + ".horizontalFilmOffset")`;	$returnArray[2] = `getAttr ($cCameraShape + ".verticalFilmOffset")`;	$returnArray[3] = `getAttr ($cCameraShape + ".filmRollValue")`;	if (attributeExists ("transparency", $shader)) // lambert		{$returnArray[4] = `getAttr ($shader + ".transparencyR")`;}	else		{$returnArray[4] = `getAttr ($shader + ".opacityR")`;}	return $returnArray;	 	}global proc panandtrackDrag(float $overscan, float $horiFilmOffset, float $vertFilmOffset, float $filmRollValue, float $r)	{	float  $dragPosition[] = `draggerContext -query -dragPoint panandtrackContext`;	int    $button     = `draggerContext -query -button panandtrackContext`;	string $getMod = `draggerContext -query -mo panandtrackContext`;	float $pressPosition[] = `draggerContext -query -anchorPoint panandtrackContext`; 		//string $shader = `textFieldGrp -q -text apssGroup`;	global string $gPanScanShader;	string $shader = $gPanScanShader;	string $cPanel = `getPanel -withFocus`;	string $cCamera = `modelPanel -q -cam $cPanel`; 	string $cCameraShape = $cCamera;	// adjusted for backward compatability 6/27/2016 Baier	if (`nodeType $cCamera` == "transform")		{			string $tmpShape[] = `listRelatives -s -ni $cCamera`;			$cCameraShape = $tmpShape[0];		}	$cOS = `getAttr ($cCameraShape + ".overscan")`;			if ($button == 1 && $getMod != "ctrl")			//modify overscan to zoom in (right) and out (left)		{		$amt = ($dragPosition[0] - $pressPosition[0]);						float $nOS = $overscan - ($amt * 0.005);				if ($nOS > 0.01)			{			setAttr ($cCameraShape + ".overscan") $nOS;			refresh;			} 		else 			{			setAttr ($cCameraShape + ".overscan") 0.01;			}		} 	else if ($button == 1 && $getMod =="ctrl")		//modify offsets to scan		{		$amtX = ($dragPosition[0] - $pressPosition[0]);		$amtY = ($dragPosition[1] - $pressPosition[1]);					float $nX = $horiFilmOffset - ($amtX * 0.003) * $cOS * cosd($filmRollValue) + ($amtY * 0.003) * $cOS * sind($filmRollValue);		float $nY = $vertFilmOffset - ($amtX * 0.003) * $cOS * sind($filmRollValue) - ($amtY * 0.003) * $cOS * cosd($filmRollValue);				setAttr ($cCameraShape + ".horizontalFilmOffset") $nX;		setAttr ($cCameraShape + ".verticalFilmOffset") $nY;		refresh;		}	else if ($button == 2 && $getMod != "ctrl")		//modify transparency		{		$amt = ($dragPosition[0] - $pressPosition[0]);				float $nTRN = $r - ($amt * 0.005);				if (attributeExists ("transparency", $shader)) // lambert			{				if ($nTRN < 0.0)					{					setAttr ($shader + ".transparencyR") 0.0;					setAttr ($shader + ".transparencyG") 0.0;					setAttr ($shader + ".transparencyB") 0.0;					} 				else if ($nTRN > 1.0)					{					setAttr ($shader + ".transparencyR") 1.0;					setAttr ($shader + ".transparencyG") 1.0;					setAttr ($shader + ".transparencyB") 1.0;					}				else 					{					setAttr ($shader + ".transparencyR") $nTRN;					setAttr ($shader + ".transparencyG") $nTRN;					setAttr ($shader + ".transparencyB") $nTRN;					refresh;					}			}		else	// blinn			{				if ($nTRN < 0.0)					{					setAttr ($shader + ".opacityR") 0.0;					setAttr ($shader + ".opacityG") 0.0;					setAttr ($shader + ".opacityB") 0.0;					} 				else if ($nTRN > 1.0)					{					setAttr ($shader + ".opacityR") 1.0;					setAttr ($shader + ".opacityG") 1.0;					setAttr ($shader + ".opacityB") 1.0;					}				else 					{					setAttr ($shader + ".opacityR") $nTRN;					setAttr ($shader + ".opacityG") $nTRN;					setAttr ($shader + ".opacityB") $nTRN;					refresh;					}			}		}	else if ($button == 2 && $getMod =="ctrl") 		//modify roll		{				$amt = ($dragPosition[0] - $pressPosition[0]);		float $origroll = $filmRollValue - ($amt * .05) * $cOS;		setAttr ($cCameraShape + ".filmRollValue") $origroll;		refresh;		}	}