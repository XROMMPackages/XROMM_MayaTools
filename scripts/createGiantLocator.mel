/* global proc string createGiantLocator(string $name)

   obsolete in XROMM_MayaTools_2_1_8

   retained for backwardCompatability
   Written by David Baier
*/
global proc string createGiantLocator(string $name)
{
    axesCreateUI;
    textFieldGrp -e -text $name coordNameUI;
    return "axesCreateUI";
}