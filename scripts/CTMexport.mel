/*global proc CTMexport()
    GUI to export xyz coordinates for Marker centroids.
    Written by David Baier
*/
global proc CTMexport()
{
	if (`window -exists CTMexportWindow` == true) deleteUI CTMexportWindow;  

	int $height = 320;
	int $width = 500;

	string $mainWindow = `window -title "Marker Export" -menuBar true -maximizeButton false -minimizeButton true
		-sizeable true -resizeToFitChildren false CTMexportWindow`;
		
	columnLayout;
		rowColumnLayout -numberOfColumns 3 -cw 1 ($width*0.4) -cw 2 ($width*0.2) -cw 3 ($width*0.4);
			columnLayout;
				text "All Locators (double-click to rename)";
				textScrollList
					-allowMultiSelection 1 -w ($width*0.4) -sc allLocatorListSelectCmd
					-dcc "renameLocatorCmd(\"allLocatorList\")" 
					-dragCallback allLocatorDrag -dropCallback allLocatorDrop -nr 15 allLocatorList;
			setParent..;
			columnLayout;
				text " ";
				text " ";
				text " ";
				button -label "sortA-Z Left" -al "center" -w ($width*0.19) -c sortLeftButtonCmd sortLeftButton;
				button -label "sortA-Z Right" -al "center" -w ($width*0.19) -c sortRightButtonCmd sortRightButton;
				text " ";
				text -al "center" -w ($width*0.19) "Middle" ;
				text -al "center" -w ($width*0.19) "Mouse" ;
				text -al "center" -w ($width*0.19) "<--Drag--> " ;
			setParent..;
			columnLayout;
				text "Export Locators";
				textScrollList
					-allowMultiSelection 1 -w ($width*0.4) -sc selLocatorListSelectCmd 
					-dcc "renameLocatorCmd(\"selectedLocatorList\")" 
					-dragCallback selLocatorDrag -dropCallback selLocatorDrop -nr 15 selectedLocatorList;
			setParent..;		
		setParent..;
		text " ";
	    //textFieldButtonGrp -label "Rename Centroid" -text "Type the new name" -buttonLabel "Rename" 
		//-buttonCmd renameCentroidCmd renameFieldGroup;
	button	-label "Export to .csv file" -w ($width-20) -command runCTMexport ctmExportButton;

	button	-label "Close" -w ($width-20) closeButton;
	button -edit -command "deleteUI CTMexportWindow" closeButton;

	showWindow $mainWindow;
	window -e -width $width -height $height $mainWindow;
	
	string $objs[] = sort(`ls  -et "locator"`);
	$objs = `listRelatives -parent $objs`;
	for($obj in $objs)
		{textScrollList -edit -append $obj allLocatorList;}
	updateOnSelCmd;
	scriptJob -p $mainWindow -e "SelectionChanged" updateOnSelCmd;	
	scriptJob -p $mainWindow -e "NameChanged" updateOnSelCmd;	
}

global proc allLocatorListSelectCmd()
{
    // selects object(s) selected in the left list
	string $name[] = `textScrollList -q -si allLocatorList`;
	select $name;
	//textFieldButtonGrp -e -text $name[0] renameFieldGroup;
}

global proc selLocatorListSelectCmd()
{
    // selects object(s) selected in the left list
	string $name[] = `textScrollList -q -si selectedLocatorList`;
	select $name;
	//textFieldButtonGrp -e -text $name[0] renameFieldGroup;
}

global proc updateOnSelCmd()
{
    // script job attached to CTMexportWindow
    // object selected in scene, will be selected in the lists
	string $sel[] = `ls -sl`;
	string $allList[] = `textScrollList -q -ai allLocatorList`;
	string $selList[] = `textScrollList -q -ai selectedLocatorList`;
	if (size($sel)>0)
	{
		textScrollList -e -da allLocatorList;
		for ($s in $sel)
		{
			if (stringArrayContains($s, $allList))
				{textScrollList -e -si $s allLocatorList;}
			if (stringArrayContains($s, $selList))
				{textScrollList -e -si $s selectedLocatorList;}
		}
	}
	// now remove any that no longer exist
	for ($a in $allList)
	{ if (!`objExists $a`)
	    {textScrollList -edit -removeItem $a allLocatorList;}
	}
	
	for ($s in $selList)
	{ if (!`objExists $s`)
	    {textScrollList -edit -removeItem $s selectedLocatorList;}
	}
}

global proc sortLeftButtonCmd()
{
    string $curAllList[] = `textScrollList -q -ai allLocatorList`;
    $curAllList = sort($curAllList);
    textScrollList -edit -removeAll allLocatorList;
	for($c in $curAllList)
			{textScrollList -edit -append $c allLocatorList;}
    
}

global proc sortRightButtonCmd()
{
   string $curAllList[] = `textScrollList -q -ai selectedLocatorList`;
    $curAllList = sort($curAllList);
    textScrollList -edit -removeAll selectedLocatorList;
	for($c in $curAllList)
			{textScrollList -edit -append $c selectedLocatorList;}
}

global proc string[] allLocatorDrag(string $dragControl, int $x, int $y, int $mods)
{
    return {$dragControl};
}

global proc allLocatorDrop(string $drag, string $drop, string $msgs[],int $x, int $y, int $type)
{
    if ((`gmatch  $drop "*allLocatorList"`) && (`gmatch  $drag "*selectedLocatorList"`))
    {
        string $name[] = `textScrollList -q -si $drag`;
        for ($n in $name)
            {textScrollList -edit -append $n $drop;
            textScrollList -edit -removeItem $n $drag;
            textScrollList -e -si $n $drop;}		
	}
	print ($drag+"\n"+$drop);
}

global proc string[] selLocatorDrag(string $dragControl, int $x, int $y, int $mods)
{
    return {$dragControl};
}

global proc selLocatorDrop(string $drag, string $drop, string $msgs[],int $x, int $y, int $type)
{
 
    if ((`gmatch  $drop "*selectedLocatorList"`) && (`gmatch  $drag "*allLocatorList"`))
    {
         string $name[] = `textScrollList -q -si $drag`;
         for ($n in $name)
            {textScrollList -edit -append $n $drop;
            textScrollList -edit -removeItem $n $drag;
            textScrollList -e -si $n $drop;}
	}
	print ($drag+"\n"+$drop);  
}




global proc renameLocatorCmd(string $listCtrl)
{
	// selected object in All Locators
	string $curName[] = `textScrollList -q -si $listCtrl`;
	
	string $result = `promptDialog -title "Rename" -text $curName
        -button "OK" -button "Cancel" -defaultButton "OK" -cancelButton "Cancel"
        -dismissString "Cancel"`;
        
    if ($result == "OK")
    {
        // rename the locator
        string $newName = `promptDialog -query -text`;
        $newName = cleanStrForObjectName($newName);
		string $actualNewname = `rename $curName[0] $newName`;
	
		// update the list
        int $idx[] = `textScrollList -q -sii $listCtrl`;
        textScrollList -e -rii $idx[0] $listCtrl;
        textScrollList -e -ap $idx[0] $actualNewname $listCtrl;
	
		// if vAv2 was used, rename the mesh that goes with it
		string $meshName = `substitute "vAvg2" $curName[0] ""`;
		if (`objExists $meshName`){rename $meshName ($actualNewname+"Mesh");}
		// if the mesh was already renamed by this script, we can get that name and rename it again
		string $alreadyRenamedMesh = `substitute "vAvg2" $curName[0] "Mesh"`;
		if (`objExists $alreadyRenamedMesh`){rename $alreadyRenamedMesh ($actualNewname+"Mesh");}
	}
}
