global proc string headerList(string $objs[], string $atts[])
{
	string $sVals[];
	for ($i = 0; $i < (size($objs)); $i++)
		{
			for ($j = 0; $j < (size($atts)); $j++)
				{$sVals[size($sVals)] = ($objs[$i] + "." + $atts[$j]);}
		}
    string $headerList = stringArrayToString($sVals, ",");
    return $headerList;
}

global proc int isKeyedExp(string $obj, string $att, float $frame)
{
	int $iskeyed;
	
	string $objatt = ($obj + "." + $att);
	float $k[];		
	// selected objects only
	if (`radioButtonGrp -q -sl kfoRadio` == 1)
	{
		if ($att == "m")
			{$k = `keyframe -hi "none" -t $frame -q -tc $obj`;}
		else
			{$k = `keyframe -hi "none" -t $frame -q -tc $objatt`;}
	}
	// hierarchy
	else if (`radioButtonGrp -q -sl kfoRadio` == 2)
	{
	    string $objs[] = `listRelatives -ap $obj`; string $objsatt[];
	    for ($i = 0; $i < size($objs); $i++){$objsatt[$i] = ($objs[$i]+"."+$att);}
	    
		if ($att == "m")
			{$k = `keyframe -hi "both" -t $frame -q -tc $objs`;}
		else
			{$k = `keyframe -hi "both" -t $frame -q -tc $objsatt`;}
	}
	/*// all objects in scene
	else if (`radioButtonGrp -q -sl kfoRadio` == 3)
	{
		string $allTransforms[] = `ls -type "transform"`;
		string $allCameras[] = `listCameras`;
		string $shortTformList[] = stringArrayRemove($allCameras, $allTransforms);
		$k = `keyframe -hi "both" -t $frame -q -tc $shortTformList`;
	}*/
	// direct parent only
	else if (`radioButtonGrp -q -sl kfoRadio` == 3)
	{
		string $parents[] = `listRelatives -ap $obj`;
		$k = `keyframe -hi "none" -t $frame -q -tc ($parents[0]+"."+$att)`;
	}
	if (size($k) == 0)
		{$iskeyed = 0;}
	else
		{$iskeyed = 1;}

	return $iskeyed;
}

global proc string[] getEXPflagatts(string $curflag)
{
	string $outstring[];
	if ($curflag == "-t")
		{$outstring = {"tx","ty","tz"};}
    else if($curflag == "-ro")
		{$outstring = {"rx","ry","rz"};}
	else if($curflag == "-m")
		{$outstring = {"m","m","m","m","m","m","m","m","m","m","m","m","m","m","m","m"};}
	else{}
	return $outstring;
}

global proc string[] wireFrameSwitch()
{
	string $cPanels[] = `getPanel -vis`;
	string $origDisp[];
	for ($cPanel in $cPanels)
	{
		if (`modelPanel -exists $cPanel`){
		$origDisp[size($origDisp)] = `modelEditor -q -displayAppearance $cPanel`;
		modelEditor -edit -displayAppearance wireframe $cPanel;}
	}
	return $origDisp;
}

global proc wireFrameReturnOrig(string $origDisp[])
{
	string $cPanels[] = `getPanel -vis`;
	for ($i = 0;$i<size($cPanels);$i++)
		{	if (`modelPanel -exists $cPanels[$i]`)	
		{modelEditor -edit -displayAppearance $origDisp[$i] $cPanels[$i];}
	}
}

/***************************************************************************
************************ Export PROCS **************************************
***************************************************************************/

/************************ Export Xform ***********************/

global proc expXform(string $pointfile, string $flags[], string $atts[])
{
// use expXform for matrices and global values

	// if autokeyframe is on, turn it off and store the value to return
    int $turnAutoBackOn = `autoKeyframe -q -state`;
    if (`autoKeyframe -q -state` == 1){autoKeyframe -state 0;}
    
	//list selected objs
	string $objs[] = `ls -selection`;
	float $vals[]; string $sVals[]; string $xcord; int $iskeyed;
	
	// flag for xform coordinate system
	if (`radioButtonGrp -q -sl coordTypeRadio` == 1)
		{$xcord = "-ws";} else {$xcord = "-os";}
	
	// open file for writing
	$fileId = `fopen $pointfile "w"`;
	
	// print headers
	if ((`checkBox -q -v rheaderCheck`) && (`checkBox -q -v cheaderCheck`))
		{fprint $fileId "frame,";}
	
	if(`checkBox -q -v cheaderCheck`)
		{string $headerList = headerList($objs,$atts);
		fprint $fileId ($headerList + "\n");}
	
	// get first and last frame from gui
	float $frame = `floatField -q -value startFr`;
	float $lastframe = `floatField -q -value expEndFr`;	
	
	// spline interpolate prevents nans from printing if exporting from a single frame
	if ($frame == $lastframe)
		{radioButtonGrp -edit -sl 1 interpolateRadio;}

	// create nans to first frame 
	if(`checkBox -q -v nanSpacingCheck`)
	{		
		int $numColumns = (size($objs)*size($atts));
		string $nan[];
		for ($i = 1; $i<$frame;$i++)
			{
				if(`checkBox -q -v rheaderCheck`){fprint $fileId ($i + ",");}
				for ($j = 0; $j<$numColumns;$j++)
					{$nan[size($nan)] = "NaN";}
				string $nanrow = stringArrayToString($nan,",");
				fprint $fileId ($nanrow + "\n");
				clear($nan);
			}
	}
	
	// get frame list
	int $frameList[]; float $curfr;
	if(`checkBox -q -v nanSpacingCheck`)
	{
		for ($i = $frame; $i<=$lastframe; $i++)
			{$frameList[size($frameList)] = $i;}
	}
	else
	{
	    if(`radioButtonGrp -q -sl kfoRadio` == 1)
	        {int $curfr = `findKeyframe -which "first" $objs`;}
	    else if (`radioButtonGrp -q -sl kfoRadio` == 2)
	        {int $curfr = `findKeyframe -which "first" -hi "both" $objs`;}
	    else if (`radioButtonGrp -q -sl kfoRadio` == 3)
	        {string $allobs = `ls -tr`; int $curfr = `findKeyframe -which "first" $allobs`;}
		currentTime -update 0 -edit $curfr;
		$frameList[0] = $curfr;
		while( $curfr < $lastframe)
			{
			    if(`radioButtonGrp -q -sl kfoRadio` == 1)
			        {$curfr = `findKeyframe -which "next" $objs`;}
			    else if (`radioButtonGrp -q -sl kfoRadio` == 2)
			        {int $curfr = `findKeyframe -which "next" -hi "both" $objs`;}
			    else if (`radioButtonGrp -q -sl kfoRadio` == 3)
			        {string $allobs = `ls -tr`; int $curfr = `findKeyframe -which "next" $allobs`;}
				currentTime -update 0 -edit $curfr;
				$frameList[size($frameList)] = $curfr;
			}
	}
		

	progressWindow -title "Exporting Data" -min ($frame) -max ($lastframe+1)
			 -progress ($frame) -status ("Processing frame: " + ($frame)) -isInterruptable true;	

	for ($i in $frameList)
	{

		currentTime -update 1 -edit $i;
		
		if (`checkBox -q -v rheaderCheck`)
			{fprint $fileId ($i + ",");}
		
		for ($obj in $objs)
		{
			for ($flag in $flags)
			{
				$vals = eval("xform " + $xcord + " -q " + $flag + " " + $obj);
				// spline interpolate
				if(`radioButtonGrp -q -sl interpolateRadio` == 1)
				{
					for ($val in $vals)
					{$sVals[size($sVals)] = string($val);}
				}
				// keyframes only
				else if (`radioButtonGrp -q -sl interpolateRadio` == 2)
				{
					string $curatts[] = getEXPflagatts($flag);
					for ($j = 0; $j<size($vals); $j++)
					{
					    // this is problematic when not keyframed object
					    // bug needs fixed
						$iskeyed = isKeyedExp($obj,$curatts[$j], $i);
						if (!$iskeyed)
							{$sVals[size($sVals)] = "NaN";}
						else
							{$sVals[size($sVals)] = string($vals[$j]);}
					}	
				}
			}
		}
		fprint $fileId (stringArrayToString($sVals,","));
		if ($i != $lastframe)
			{fprint $fileId "\n";}
		clear($sVals);
		clear($vals);
		if ( `progressWindow -query -isCancelled` ) 
		{break;}
		progressWindow -edit -progress $i -status ("Processing frame: " + $i);
	}
	progressWindow -endProgress;
	fclose $fileId;
	print ("\/\/Export "+$pointfile+" complete.\n");
	
	if ($turnAutoBackOn){autoKeyframe -state 1;}
}

/************************ Export getAttr ***********************/

global proc expGetAttr(string $pointfile, string $atts[])
{
	// if this autokeyframe is on, turn it off and store the value to return
    int $turnAutoBackOn = `autoKeyframe -q -state`;
    if (`autoKeyframe -q -state` == 1){autoKeyframe -state 0;}
    
	//list selected objs
	string $objs[] = `ls -selection`;
	float $val; string $sVals[]; int $isKeyedExp;
	
	// open file for writing
	$fileId = `fopen $pointfile "w"`;

	// print headers
	if ((`checkBox -q -v rheaderCheck`) && (`checkBox -q -v cheaderCheck`))
		{fprint $fileId "frame,";}
	
	if(`checkBox -q -v cheaderCheck`)
	{string $headerList = headerList($objs,$atts);
		fprint $fileId ($headerList + "\n");}
	
	// get first and last frame from gui
	float $frame = `floatField -q -value startFr`;
	float $lastframe = `floatField -q -value expEndFr`;
	
	// create nans until first frame		
	if(`checkBox -q -v nanSpacingCheck`)
	{	
		int $numColumns = (size($objs)*size($atts));
		string $nan[];		
		for ($i = 1; $i<$frame;$i++)
			{
				if(`checkBox -q -v rheaderCheck`){fprint $fileId ($i + ",");}
				for ($j = 0; $j<$numColumns;$j++)
					{
						$nan[size($nan)] = "NaN";
					}
				string $nanrow = stringArrayToString($nan,",");
				fprint $fileId ($nanrow + "\n");
				clear($nan);
			}
	}
	
	// get frame list
	int $frameList[];
	if(`checkBox -q -v nanSpacingCheck`)
	{
		for ($i = $frame; $i<=$lastframe; $i++)
			{$frameList[size($frameList)] = $i;}
	}
	else
	{
		int $curfr = `findKeyframe -which "first" $objs`;
		currentTime -update 0 -edit $curfr;
		$frameList[0] = $curfr;
		while( $curfr < $lastframe)
			{
				$curfr = `findKeyframe -which "next" $objs`;
				currentTime -update 0 -edit $curfr;
				$frameList[size($frameList)] = $curfr;
			}
	}

	for ($i in $frameList)
	{  
		// print frame number in first column if needed
		if (`checkBox -q -v rheaderCheck`)
			{fprint $fileId ($i + ",");}
		// for each selected object
		for ($j = 0; $j < (size($objs)); $j++)
		{
			// and for each attribute in the list
			for ($k = 0; $k < (size($atts)); $k++)
			{
				// if only key frames - do this
				if (`radioButtonGrp -q -sl interpolateRadio` == 2)
				{
					$iskeyed = isKeyedExp($objs[$j],$atts[$k], $i);
					if (!$iskeyed)
						{$sVals[size($sVals)] = "NaN";}
					else
						{$val = `getAttr -t $i ($objs[$j] + "." + $atts[$k])`;
						$sVals[size($sVals)] = string($val);}
				}
				// if every frame do this
				else
				{
					$val = `getAttr -t $i ($objs[$j] + "." + $atts[$k])`;
					$sVals[size($sVals)] = string($val);
				}
			}
		}
		fprint $fileId (stringArrayToString($sVals,","));
		if ($i != $lastframe)
			{fprint $fileId "\n";}
		clear($sVals);
	}	
	fclose $fileId;
	print ("\/\/Export "+$pointfile+" complete.\n");
	
	if ($turnAutoBackOn){autoKeyframe -state 1;}
}

