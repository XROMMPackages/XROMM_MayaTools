/************************ Export Distance ***********************/

global proc expdist2(string $pointfile)
{
	/* expdist2(string $pointfile)
		Exports data from a distance tool in maya
		
		$pointfile: full path and file name for output		
	*/
	string $origDisp[] = wireFrameSwitch();
    string $objs[] = `ls -selection`;
    string $objShapes[] = `listRelatives -s -ni $objs`; 
    
    float $vals[]; string $sVals[];
    string $atts[] = {"startPoint","endPoint"};
    
    float $frame = `floatField -q -value startFr`;
	float $lastframe = `floatField -q -value expEndFr`;
	
	$fileId = `fopen $pointfile "w"`;

	// create nans to first frame 
	if(`checkBox -q -v nanSpacingCheck`)
	{		
		int $numColumns = (size($objs)*size($atts));
		string $nan[];
		for ($i = 1; $i<$frame;$i++)
			{
				if(`checkBox -q -v rheaderCheck`){fprint $fileId ($i + ",");}
				for ($j = 0; $j<$numColumns;$j++)
					{$nan[size($nan)] = "NaN";}
				string $nanrow = stringArrayToString($nan,",");
				fprint $fileId ($nanrow + "\n");
				clear($nan);
			}
	}
	
	if(`checkBox -q -v cheaderCheck`)
        {
            fprint $fileId "frame,";
            string $headerList = headerList($objs,{"dist"});
            fprint $fileId ($headerList + "\n");
        }
    for ($i = $frame; $i<= $lastframe; $i++)
    {
        currentTime -edit $i;
        
        if (`checkBox -q -v rheaderCheck`)
			{fprint $fileId ($i + ",");}
       
        for ($obj in $objShapes)
        {
            vector $a = `getAttr($obj+".startPoint")`;
            vector $b = `getAttr($obj+".endPoint")`;
            $vals[size($vals)] = mag($a - $b);
        }
        for ($val in $vals)
            {$sVals[size($sVals)] = string($val);}
        
        fprint $fileId (stringArrayToString($sVals,",") + "\n");
        clear($vals);
		clear($sVals);
    }
    fclose $fileId;
    wireFrameReturnOrig($origDisp);
}

