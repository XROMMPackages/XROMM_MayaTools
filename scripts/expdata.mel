/* global proc expdata()

    GUI for exporting a variety of data types
    Exports  data either keyframed or from a static object
    
	Data type: currently supported types of data for export
	Coordinate system: local or global
	Frame start and end: determines which frames will be exported
	
	Options
	***user is forced to keep track of frame number either by leading NaNs for 
	 frames prior to startframe or by keeping the frame number in the first row
 	Column Headers: will include the name of the object and attribute as the 
 	    header in each column.
	Frame# in first row: the first column will include the frame number
	
	Advanced options 
	    User can populate start and end frames based on current object keys, keyframes
	        on any object in the selected objects hierarchy, all keyframes in the scene,
	        or directly from the time slider.
	    
	    spline interpolation. If Yes - spline data will fill all values between start
	        and end frames. If No - and frame numbers are not checked, NaN values will
	        fill non-keyed frames. If No - Nan's fill non-keyed frames
	    		
        Written by David Baier  08/03/2013 
 */
global proc expdata()
{
	// get initial time values based on keyframes for selected objects
	float $firstframe = `findKeyframe -hi both -which first`;
	float $lastframe = `findKeyframe -hi both -which last`;
	
	if (`window -exists expDataWindow` == true) deleteUI expDataWindow;  

	int $height = 400;
	int $width = 400;
  
	string $mainWindow = `window -title "Export Data" -maximizeButton false
		-minimizeButton true -sizeable true -resizeToFitChildren false expDataWindow`;
	columnLayout;
   
	text " ";

	rowColumnLayout -numberOfColumns 2 -cw 1 ($width/2) -cw 2 ($width/2 - 10) rc1;
		frameLayout -label "Data type" -bv 1 expFL1;
			columnLayout;
					radioCollection typeCollection;
						radioButton 	-label  "Translation" rbtrans1;
						radioButton 	-label  "Rotation" rbrot2;
						radioButton 	-label  "Translation/Rotation" rbtransrot3;
						radioButton 	-label  "Matrix (maya format)" rbmatrixt4;
						radioButton 	-label  "Selected Attributes" -cc selAttCommand rbselattr5;
						radioButton 	-label  "Distance" -cc distChangeCommand rbdist6;
						button -label "Export .obj" -c "expObj({},{})" expvcButton;			
						text " ";
						text -font "boldLabelFont" -label "Coordinate system" -width ($width/2-10) -al "left";
						radioButtonGrp 	-numberOfRadioButtons 2 -vr
										-labelArray2 "Global" "Local"
										coordTypeRadio;
						radioButtonGrp -edit -sl 1 coordTypeRadio;
						text " ";
						rowColumnLayout -numberOfColumns 2 -cw 1 ($width/4 - 10) -cw 2 ($width/4 - 10) rc2;
							text"Start frame";
							text"End frame";
							floatField -en 1 startFr;
							floatField -en 1 expEndFr;
							text " ";
						setParent ..;
				setParent ..;
			setParent ..;
		frameLayout -label "Options" -bv 1 expFL2;
			columnLayout;
					checkBox -label "Column Headers" -value 1 
					-ann "Each column will have the name of the object_attribute (e.g. bone_tx)" cheaderCheck;
					checkBox -label "Row Headers (frame#)" -value 0 
					-ann "Each row will have the frame number in the first column" rheaderCheck;
					checkBox -label "Keep frame spacing" -value 1 -cc nanSpacingCheckCommand 
					-ann "Frames with no data are listed as Nan (not a number). If data starts at frame 50, the file will fill the first 49 rows with Nan values" nanSpacingCheck;
					text -label "       with NANs" nanSpacingCheck2;
					text " ";
					radioButtonGrp 	-numberOfRadioButtons 2 -vr
										-labelArray2 "single file" "multiple files"
										fileNumRadio;
                    radioButtonGrp 	-edit -sl 1 fileNumRadio;										
					text " ";
					checkBox -label "Export current values only (no animation)" -value 0 -cc curValOnlyCommand curValOnlyCheck;
					text " ";	
					text -label "Start and end frames from:" -en 1 kfoTxt;
					radioButtonGrp -numberOfRadioButtons 4 -vr -en 1 -cc updateFramesCommand -vis 1
								   -labelArray4 "Selected objects only" "Hierarchy of selected objects" "Parent of selected objects" "Timeslider"  
									kfoRadio;
					radioButtonGrp -edit -sl 1 kfoRadio;
					// kfo will need more options - ideally a button for parent and a final option to choose what object has the keys
					text " ";
					text -label "Spline Interpolate unkeyed frames?:" -en 1 interpolateTxt;
					radioButtonGrp -numberOfRadioButtons 2 -vr -cc updateFramesCommand -en 1
								   -labelArray2 "Yes" "No"
								   interpolateRadio;
					radioButtonGrp -edit -sl 2 interpolateRadio;
					
				setParent ..;
			setParent ..;
			text " ";
		setParent..;
    text " ";
	button	-label "Export" -w $width -command ("exportType({},{})") impButton;
	button	-label "Close" -w $width closeButton;
	button -edit -command "deleteUI expDataWindow" closeButton;

	showWindow $mainWindow;
	window -e -width $width -height $height $mainWindow;
	
	//floatField -edit -value $firstframe startFr;
	//floatField -edit -value $lastframe expEndFr;
	updateFramesCommand;
	scriptJob -p $mainWindow -e "SelectionChanged" updateFramesCommand;
}


/************************************************************
******************* BUTTON CLICK PROCS **********************
*************************************************************/
global proc exportType(string $pointfiles[],string $attrs[])
{
    string $objs[] = `ls -sl`;
	// get file or directory
	if (size($pointfiles) == 0)
	{  
	    if (`radioButtonGrp -q -sl fileNumRadio` == 1)
	        {$pointfiles = getXrommPointfiles("Save as",0,"CSV files (*.csv)",1);}
	    else
	        {
	            string $savedir[] = getXrommPointfiles("Select directory",2,"CSV files (*.csv)",1);
	            for ($o in $objs)
	            {
	                $o = substituteAllString($o, ":", "");
	                $pointfiles[size($pointfiles)] = ($savedir[0]+"/"+$o+".csv");
	            }
	        }
	}
	
	// if names of selected attrs aren't passed to script, get from channelbox
	if(`radioButton -q -sl rbselattr5`)
	{
		if (size($attrs) == 0)
			{$attrs = `channelBox -q -sma "mainChannelBox"`;}
	}
	
    // counter for multiple file export - unused if single file   
    int $counter = 0;  
	    
    // loop through files
    for ($pointfile in $pointfiles)
    {
        string $fileNcheck = (dirname($pointfile));
        
        if (`filetest -d $fileNcheck`)
        {
            $pointfile = `substituteAllString $pointfile ".csv" ""`;
            $pointfile = $pointfile +".csv";
            
            // if multiple files
            if (`radioButtonGrp -q -sl fileNumRadio` == 2)
                 {select -r $objs[$counter]; $counter++; updateFramesCommand;}
                    
            // global option
            if (`radioButtonGrp -q -sl coordTypeRadio` == 1)
            {
                if (`radioButton -q -sl rbtrans1`)
                    {expXform($pointfile, {"-t"}, {"tx","ty","tz"});}
                else if(`radioButton -q -sl rbrot2`)
                    {expXform($pointfile, {"-ro"}, {"rx","ry","rz"});}
                else if(`radioButton -q -sl rbtransrot3`)
                    {expXform($pointfile, {"-t","-ro"}, {"tx","ty","tz","rx","ry","rz"});}
                else if(`radioButton -q -sl rbmatrixt4`)
                    {expXform($pointfile, {"-m"}, {"rxx","rxy","rxz","rx0","ryx","ryy","ryz","ry0","rzx","rzy","rzz","rz0","tx","ty","tz","t1"});}
                else if(`radioButton -q -sl rbselattr5`)
                    {expGetAttr($pointfile,($attrs));}
                else if(`radioButton -q -sl rbdist6`)
                    {expdist2($pointfile);}
                else
                {confirmDialog 	-title "Need More Info" -message "You must select a data type" 
                    -button "OK" -defaultButton "OK";} 
            }
            // local option
            else if (`radioButtonGrp -q -sl coordTypeRadio` == 2)
            {
                if (`radioButton -q -sl rbtrans1`)
                    {expGetAttr($pointfile, {"tx","ty","tz"});}
                else if(`radioButton -q -sl rbrot2`)
                    {expGetAttr($pointfile, {"rx","ry","rz"});}
                else if(`radioButton -q -sl rbtransrot3`)
                    {expGetAttr($pointfile, {"tx","ty","tz","rx","ry","rz"});}
                 else if(`radioButton -q -sl rbmatrixt4`)
                    {expXform($pointfile, {"-m"}, {"rxx","rxy","rxz","rx0","ryx","ryy","ryz","ry0","rzx","rzy","rzz","rz0","tx","ty","tz","t1"});}
                else if(`radioButton -q -sl rbselattr5`)
                    {expGetAttr($pointfile,($attrs));}
                else if(`radioButton -q -sl rbdist6`)
                    {expdist2($pointfile);}
                else
                {confirmDialog 	-title "Need More Info" -message "You must select a data type" 
                    -button "OK" -defaultButton "OK";} 
            }
        }
        else
        {
            confirmDialog 	-title "Error" -message "Export Cancelled" 
                    -button "OK" -defaultButton "OK";
        }
    }
}

global proc selAttCommand()
{
	// if select attributes, currently must do local, but shouldn't have to
	if(`radioButton -q -sl rbselattr5`)
		{radioButtonGrp -edit -sl 1 -en 0 coordTypeRadio;}
	else
		{radioButtonGrp -edit -sl 2 -en 1 coordTypeRadio;}
}

global proc nanSpacingCheckCommand()
{
	if(`checkBox -q -v nanSpacingCheck`)
		{checkBox -e -en 1 rheaderCheck;}
	else
		{checkBox -e -v 1 -en 0 rheaderCheck;}
}

global proc arcCommand()
{
	if(`radioButton -q -sl rbarc6`)
		{radioButtonGrp -edit -sl 1 -en 0 coordTypeRadio;}
	else
		{radioButtonGrp -edit -sl 1 -en 1 coordTypeRadio;}
}

global proc distChangeCommand()
{
    if(`radioButton -q -sl rbdist6`)
		{radioButtonGrp -edit -sl 1 -en 0 coordTypeRadio;
        checkBox -edit -value 0 -enable 0 nanSpacingCheck;
        radioButtonGrp -edit -sl 1 -en 0 coordTypeRadio;
        }
	else
		{radioButtonGrp -edit -sl 1 -en 1 coordTypeRadio;
        checkBox -edit -value 1 -enable 1 nanSpacingCheck;
        radioButtonGrp -edit -sl 1 -en 1 coordTypeRadio;}
}

global proc curValOnlyCommand()
{

	if (`checkBox -q -v curValOnlyCheck`)
	{
		text -e -enable 0 kfoTxt;
		radioButtonGrp -e -enable 0 kfoRadio;
		text -e -enable 0 interpolateTxt;
		radioButtonGrp -e -enable 0 interpolateRadio;
    }
    else
    {
    	text -e -enable 1 kfoTxt;
		radioButtonGrp -e -enable 1 kfoRadio;
		text -e -enable 1 interpolateTxt;
		radioButtonGrp -e -enable 1 interpolateRadio;
    }
    updateFramesCommand;
}

global proc updateFramesCommand()
{
	// If curFrameOnly
	if (`checkBox -q -v curValOnlyCheck`)
	{
		//update the gui
		float $curframe = `currentTime -q`;
		floatField -e -value $curframe startFr;
		floatField -e -value $curframe expEndFr;
	}
	else
	{
		float $firstframe = `floatField -q -value startFr`; 
		float $lastframe = `floatField -q -value expEndFr`;
	  
		// selected objects only
		if (`radioButtonGrp -q -sl kfoRadio` == 1)
		{
			$firstframe = `findKeyframe -hi none -which first`;
			$lastframe = `findKeyframe -hi none -which last`;
		}
		// hierarchy
		else if (`radioButtonGrp -q -sl kfoRadio` == 2)
		{
			$firstframe = `findKeyframe -hi both -which first`;
			$lastframe = `findKeyframe -hi both -which last`;
		}
		
		else if (`radioButtonGrp -q -sl kfoRadio` == 3)
		{
			string $parents[] = `listRelatives -ap`;
			$firstframe = `findKeyframe -hi none -which first $parents`;
			$lastframe = `findKeyframe -hi none -which last $parents`;
		}
		// use timeslider
		else if (`radioButtonGrp -q -sl kfoRadio` == 4)
		{
			$firstframe = `playbackOptions -q -minTime`;
			$lastframe = `playbackOptions -q -maxTime`;
		}
	
		//update the gui
		floatField -e -value $firstframe startFr;
		floatField -e -value $lastframe expEndFr;
	}
}

/************************************************************
************************ HelperPROCS ***********************
*************************************************************/
proc int floatArrayCount(float $item, float $list[])
// mimics stringArrayCount
// Dave Baier 3/4/2010
{
	int $result = 0;
	
	float $listItem;
	
	for ($listItem in $list) {
		if ($item == $listItem) $result++;
	}
	
	return $result;
}

proc float [] floatArrayRemoveDuplicates(float $list[])
// same as stringArrayRemoveDuplicates
{
	float $item, $result[];
	int    $index = 0;
	
	for ($item in $list) {
		if (0 == floatArrayCount($item, $result)) {
			$result[$index++] = $item;
		}
	}
	
	return $result;
}

