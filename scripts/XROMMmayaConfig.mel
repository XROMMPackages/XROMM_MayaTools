/* global proc XROMMmayaConfigUI() 	    GUI for setting up joint coordinate system        User firt estabilishes the zero pose of the proximal and distal elements    Places the joint pivot and orientation.    When the bone models have animation, running jointAxesDual calculates the relative    motion of the axes	Written by David Baier 4/1/09	last modified 3/28/2020*/global proc XROMMmayaConfigUI(){	if (`window -exists XROMMmayaConfigUIWindow` == true) deleteUI XROMMmayaConfigUIWindow;  	int $height = 200;	int $width = 500;	string $mainWindow = `window -title "Recommended XROMM configuration" -menuBar true		-maximizeButton false -minimizeButton true -sizeable true -resizeToFitChildren false		XROMMmayaConfigUIWindow`;	columnLayout;	    rowColumnLayout -numberOfColumns 3 -cw 3 ($width) xcfgRowColumn1; 	    	 text "           "; 	    	 text "           "; 	    	 text "recommended";	    setParent..;        // get up axis and select correct one        radioButtonGrp -nrb 2 -label "up axis" -labelArray2 "y" "z"             -cw 1 140 -cl3 "left" "left" "left" -cc upAxCC upAxRBgrp;           string $up = `upAxis -q -ax`;        if ($up == "y"){radioButtonGrp -e -sl 1 upAxRBgrp;}        else if ($up == "z"){radioButtonGrp -e -sl 2 upAxRBgrp;}                // tumble context        radioButtonGrp -nrb 2 -label "tumble context" -labelArray2 "on object false" "on object true "             -cw 1 140 -cl3 "left" "left" "left" -cc tumbleCC tumbleRBgrp;        if (`tumbleCtx -q -objectTumble tumbleContext`){radioButtonGrp -e -sl 2 tumbleRBgrp;}        else {radioButtonGrp -e -sl 1 tumbleRBgrp;}                // ViewCube        int $version = `about -version`;        if ($version < 2017)        {            radioButtonGrp -nrb 2 -label "view cube (only with legacy viewport)" -labelArray2 "on" "off "                 -cw 1 140 -cl3 "left" "left" "left" -cc viewCubeCC viewCubeRBgrp;            if (`viewManip -q -visible`){radioButtonGrp -e -sl 1 viewCubeRBgrp;}            else {radioButtonGrp -e -sl 2 viewCubeRBgrp;}        }                //change to background color to to remove gradient        radioButtonGrp -nrb 2 -label "background gradient" -labelArray2 "on" "off "             -cw 1 140 -cl3 "left" "left" "left" -cc brgradientCC gradientRBgrp;        if (`displayPref -q -displayGradient`){radioButtonGrp -e -sl 1 gradientRBgrp;}        else {radioButtonGrp -e -sl 2 gradientRBgrp;}            //set Playback to all cameras, continuous looping        radioButtonGrp -nrb 2 -label "playback views" -labelArray2 "active" "all "             -cw 1 140 -cl3 "left" "left" "left" -cc playbackViewsCC playbackViewsRBgrp;        string $pbViews = `playbackOptions -q -v`;        if ($pbViews == "active"){radioButtonGrp -e -sl 1 playbackViewsRBgrp;}        else if ($pbViews == "all"){radioButtonGrp -e -sl 2 playbackViewsRBgrp;}                // playback looping        radioButtonGrp -nrb 2 -label "playback looping" -labelArray2 "once" "continuous "             -cw 1 140 -cl3 "left" "left" "left" -cc playbackLoopingCC playbackLoopRBgrp;        string $pbLoops = `playbackOptions -q -loop`;        if ($pbLoops == "once"){radioButtonGrp -e -sl 1 playbackLoopRBgrp;}        else if ($pbLoops == "continuous"){radioButtonGrp -e -sl 2 playbackLoopRBgrp;}            //set Maya to native operating system dialog interface        radioButtonGrp -nrb 2 -label "file dialog style" -labelArray2 "maya" "os native "             -cw 1 140 -cl3 "left" "left" "left" -cc fileDialogCC fileDialogRBgrp;        int $fds = `optionVar -q FileDialogStyle`;        if ($fds == 2){radioButtonGrp -e -sl 1 fileDialogRBgrp;}        else if ($fds == 1){radioButtonGrp -e -sl 2 fileDialogRBgrp;}                // if the icon bars are visible (collapseIconBarsInPanels = 0),  turn them off        radioButtonGrp -nrb 2 -label "icon bars" -labelArray2 "visible" "hidden "             -cw 1 140 -cl3 "left" "left" "left" -cc iconBarsCC iconBarsRBgrp;        int $collapseIcon = `optionVar -q collapseIconBarsInPanels`;        if ($collapseIcon == 0){radioButtonGrp -e -sl 1 iconBarsRBgrp;}        else if ($collapseIcon == 1){radioButtonGrp -e -sl 2 iconBarsRBgrp;}    setParent..;	showWindow $mainWindow;	window -e -width $width -height $height $mainWindow;}global proc upAxCC(){    if (`radioButtonGrp -q -sl upAxRBgrp` == 1){setUpAxis "y";}    if (`radioButtonGrp -q -sl upAxRBgrp` == 2){setUpAxis "z";}}global proc tumbleCC(){    if (`radioButtonGrp -q -sl tumbleRBgrp` == 1){tumbleCtx -e -objectTumble 0 tumbleContext;}    if (`radioButtonGrp -q -sl tumbleRBgrp` == 2){tumbleCtx -e -objectTumble 1 tumbleContext;}}global proc viewCubeCC(){    if (`radioButtonGrp -q -sl viewCubeRBgrp` == 1){viewManip -visible 1;}    if (`radioButtonGrp -q -sl viewCubeRBgrp` == 2){viewManip -visible 0;}}global proc brgradientCC(){    if (`radioButtonGrp -q -sl gradientRBgrp` == 1){displayPref -displayGradient 1;refresh;}    if (`radioButtonGrp -q -sl gradientRBgrp` == 2){displayPref -displayGradient 0;refresh;}}global proc playbackViewsCC(){    if (`radioButtonGrp -q -sl playbackViewsRBgrp` == 1){playbackOptions -e -v "active";}    if (`radioButtonGrp -q -sl playbackViewsRBgrp` == 2){playbackOptions  -e -v "all";}}global proc playbackLoopingCC(){    if (`radioButtonGrp -q -sl playbackLoopRBgrp` == 1){playbackOptions -e -loop "once";}    if (`radioButtonGrp -q -sl playbackLoopRBgrp` == 2){playbackOptions  -e -loop "continuous";}}global proc fileDialogCC(){    if (`radioButtonGrp -q -sl fileDialogRBgrp` == 1){optionVar -iv FileDialogStyle 2;}    if (`radioButtonGrp -q -sl fileDialogRBgrp` == 2){optionVar -iv FileDialogStyle 1;}}global proc iconBarsCC(){    if (`radioButtonGrp -q -sl iconBarsRBgrp` == 1)    {    	if (`optionVar -q collapseIconBarsInPanels`) {toggleModelEditorBarsInAllPanels 1;} else {toggleModelEditorBarsInAllPanels 0;};    	optionVar -iv collapseIconBarsInPanels 0;    }         if (`radioButtonGrp -q -sl iconBarsRBgrp` == 2)    {    	if (!`optionVar -q collapseIconBarsInPanels`) {toggleModelEditorBarsInAllPanels 0;} else {toggleModelEditorBarsInAllPanels 1;};    	optionVar -iv collapseIconBarsInPanels 1;    }}