global proc float[] tmTomm(matrix $tf)
// Returns a 16 element array from a 4x4 transformation matrix input
{
	float $m[] = {($tf[0][0]),($tf[1][0]),($tf[2][0]),($tf[3][0]),
		($tf[0][1]),($tf[1][1]),($tf[2][1]),($tf[3][1]),
		($tf[0][2]),($tf[1][2]),($tf[2][2]),($tf[3][2]),
		($tf[0][3]),($tf[1][3]),($tf[2][3]),($tf[3][3])};

	return $m;
}
