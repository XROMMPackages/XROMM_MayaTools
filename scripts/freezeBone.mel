/* global proc freezeBone()    FreezeBone -- creates duplicates of two bones and calculates    motion for one bone relative to another.    12/2009 Megan M. Dawson */global proc freezeBone(){	if (`window -exists freezeBoneWindow` == true) deleteUI -wnd freezeBoneWindow;		int $height = 320;		int $width = 560;	string $mainWindow = `window	- title "Relative Bone Motion"	-menuBar true	-maximizeButton false	-minimizeButton true	-sizeable true	-resizeToFitChildren true	freezeBoneWindow`;	frameLayout - label "Create Relative Bone Motion"	-height $height	-width $width	-mw 5	-mh 5	columnLayout;	menu -label "File";	menuItem -label "Close" -command "deleteUI freezeBoneWindow";	columnLayout;	text "Step 1: Select the stationary and mobile bones";	textFieldButtonGrp		-label "Still object"		-text "Select the object you want stationary"		-buttonLabel "Insert Selection"		-buttonCommand stillSelect	stillFieldGroup;	textFieldButtonGrp		-label "Moving object"		-text "Select the object you want mobile"		-buttonLabel "Insert Selection"		-buttonCommand mobileSelect	mobileFieldGroup;	text "Step 2: Choose the frame range";		frameLayout -label "Frame Range";	    rowLayout -columnWidth4 100 100 55 75 -numberOfColumns 4;                    checkBox -label "All Keys" -onCommand animationinitiate wholesequenceframes;             checkBox -label "Timeslider" -onCommand animationinitiate timesliderframes;            checkBox -label "Section" -onCommand "intFieldGrp -edit -enable 1 startendframes" startendframescheck;            intFieldGrp -numberOfFields 2 -enable 0 -value1 0 -value2 0 -label "Start/End" -cc animationinitiate startendframes;          setParent..;    setParent..;	text "Step 3: Create copies of the bones if desired and reposition";    frameLayout -label "Choose to use duplicates or original bones";        rowLayout -columnWidth3 100 150 100 -numberOfColumns 3;                    checkBox -label "Use originals" -enable 0 -onCommand UseOriginalBones UseOriginalBonesButton; 		                    checkBox -label "Don't copy children" -enable 0 NoChildrenCopiedBox;	                    button -label "Duplicate" -enable 0 -command DuplicateBones DuplicateBonesButton;        setParent..;    setParent..;	text "Step 4: Calculate the relative motion";	button -label "Create Motion" - enable 0 -w ($width-60) -command FreezeBoneMotion FreezeBoneMotionButton;	button -label "Close" -w ($width-60) -command "deleteUI freezeBoneWindow"; 	showWindow $mainWindow;	window -e -width $width -height $height $mainWindow;}// Get the user input information as objects.global proc stillSelect(){	string $objs[] = `ls -sl`;	textFieldButtonGrp -e -text $objs[0] stillFieldGroup;}global proc mobileSelect(){	string $objs[] = `ls-sl`;	textFieldButtonGrp -e -text $objs[0] mobileFieldGroup;}	global proc animationinitiate (){	button -edit -enable 1 DuplicateBonesButton;	checkBox -edit -enable 1 UseOriginalBonesButton;	checkBox -edit -enable 1 NoChildrenCopiedBox;    if (`checkBox -q -v wholesequenceframes` == 1)     {    checkBox -edit -v 0 startendframescheck;    checkBox -edit -v 0 timesliderframes;    }    if (`checkBox -q -v startendframescheck` == 1)    {    checkBox -edit -v 0 wholesequenceframes;    checkBox -edit -v 0 timesliderframes;    }    if (`checkBox -q -v timesliderframes` == 1)    {    checkBox -edit -v 0 startendframescheck;    checkBox -edit -v 0 wholesequenceframes;    }}global proc UseOriginalBones (){	button -edit -enable 1 FreezeBoneMotionButton;	string $still = `textFieldButtonGrp -q -text stillFieldGroup`;	string $mobile = `textFieldButtonGrp -q -text mobileFieldGroup`;	string $bonegroup = ($still + $mobile);	group -n $bonegroup $still $mobile;}global proc DuplicateBones(){	string $still = `textFieldButtonGrp -q -text stillFieldGroup`;	string $mobile = `textFieldButtonGrp -q -text mobileFieldGroup`;			// Duplicate the bones if not already done and group them so that they can be moved around.	string $stillC = ($still + "Rel");	string $mobileC = ($mobile + "Rel");    if ( !(`objExists $stillC`))        {            duplicate -rc -rr -n $stillC $still;        }            duplicate -rc -rr -n $mobileC $mobile;            button -edit -enable 1 FreezeBoneMotionButton;        if (`checkBox -q -v NoChildrenCopiedBox` == 1)        {            string $allrelativesstill[] = `listRelatives -c $stillC`;            string $allshapesstill[] = `listRelatives -s $stillC`;            string $duplicatestill [] = stringArrayRemove ($allshapesstill, $allrelativesstill);            select "*Rel";            string $oldrelmobile [] = `ls -sl`;            string $duplicatestill2 [] = stringArrayRemove ($oldrelmobile, $duplicatestill);            select $duplicatestill2; delete;                string $allrelativesmobile[] = `listRelatives -c $mobileC`;            string $allshapesmobile[] = `listRelatives -s $mobileC`;            string $duplicatemobile [] = stringArrayRemove ($allshapesmobile, $allrelativesmobile);            select $duplicatemobile; delete;        }                string $bonegroup = ($still + $mobile);    group -n $bonegroup $stillC $mobileC;}//Duplicates bones, then calculates motion of one bone relative to another and applies to the duplicate.global proc FreezeBoneMotion(){	string $still = `textFieldButtonGrp -q -text stillFieldGroup`;	string $mobile = `textFieldButtonGrp -q -text mobileFieldGroup`;	int $start = 0;	int $end = 0;	if (`checkBox -q -v wholesequenceframes` == 1) 	{	$start = `findKeyframe -which first $mobile`;	$end =	`findKeyframe -which last $mobile`;	}		if (`checkBox -q -v startendframescheck` == 1)	{	$start = `intFieldGrp -q -v1 startendframes`;	$end = `intFieldGrp -q -v2 startendframes`;	}	if (`checkBox -q -v timesliderframes` == 1)	{	//select -r $mobile;	$start = `playbackOptions -q -minTime`;	$end = `playbackOptions -q -maxTime`;	}	string $stillC = ($still + "Rel");	string $mobileC = ($mobile + "Rel");	string $bonegroup = ($still + $mobile);	ungroup $bonegroup;			//Calculate and apply relative motion transforms to copy of bones	{        matrix $stilltm[4][4];        matrix $mobiletm[4][4];        matrix $mobile_1tm[4][4];        matrix $still_1tm[4][4];        matrix $finaltm[4][4];        float $mobile_1mm[16];        float $still_1mm[16];                int $frame = $start;        int $lastframe = $end;        //currentTime -edit $frame;                if (`checkBox -q -v UseOriginalBonesButton` == 1)        {            $still_1tm = mmTotm(`xform -ws -q -m $still`);           while ($frame <= $lastframe)            {                $stilltm = mmTotm(`getAttr -t $frame ($still + ".matrix")`);    //get fixed bone's tm                            $mobiletm = mmTotm(`getAttr -t $frame ($mobile + ".matrix")`);    //get mobile bone's tm                            $mobile_1tm = relativeTm($stilltm, $mobiletm);     //get jaw wrt skull tm                               $finaltm = $still_1tm*$mobile_1tm;     //multiply matrices to get final tm                            $mobile_1mm = tmTomm($finaltm);	    //convert final tm to Maya matrix                                xform -m   ($mobile_1mm[0]) ($mobile_1mm[1]) ($mobile_1mm[2]) ($mobile_1mm[3])                    ($mobile_1mm[4]) ($mobile_1mm[5]) ($mobile_1mm[6]) ($mobile_1mm[7])                    ($mobile_1mm[8]) ($mobile_1mm[9]) ($mobile_1mm[10]) ($mobile_1mm[11])                    ($mobile_1mm[12]) ($mobile_1mm[13]) ($mobile_1mm[14]) ($mobile_1mm[15]) $mobile;                                setKeyframe -at "translate" -t $frame $mobile;                setKeyframe -at "rotate" -t $frame $mobile;                                $still_1mm = tmTomm($still_1tm);                xform -m   ($still_1mm[0]) ($still_1mm[1]) ($still_1mm[2]) ($still_1mm[3])                    ($still_1mm[4]) ($still_1mm[5]) ($still_1mm[6]) ($still_1mm[7])                    ($still_1mm[8]) ($still_1mm[9]) ($still_1mm[10]) ($still_1mm[11])                    ($still_1mm[12]) ($still_1mm[13]) ($still_1mm[14]) ($still_1mm[15]) $still;                                setKeyframe -at "translate" -t $frame $still;                setKeyframe -at "rotate" -t $frame $still;                                                   $frame = $frame+1;            }        }        else         {            parent -r $mobileC $stillC;                while ($frame <= $lastframe)            {                $stilltm = mmTotm(`getAttr -t $frame ($still + ".matrix")`);		//get fixed bone's tm                            $mobiletm = mmTotm(`getAttr -t $frame ($mobile + ".matrix")`);			//get mobile bone's tm                           $mobile_1tm = relativeTm($stilltm, $mobiletm);		//get jaw wrt skull tm                                $still_1tm = mmTotm(`getAttr -t $frame ($stillC + ".matrix")`);		//get still_1's tm                           //$finaltm = $still_1tm*$mobile_1tm;				//multiply matrices to get final tm                            $mobile_1mm = tmTomm($mobile_1tm);				//convert final tm to Maya matrix                                xform -m   ($mobile_1mm[0]) ($mobile_1mm[1]) ($mobile_1mm[2]) ($mobile_1mm[3])                    ($mobile_1mm[4]) ($mobile_1mm[5]) ($mobile_1mm[6]) ($mobile_1mm[7])                    ($mobile_1mm[8]) ($mobile_1mm[9]) ($mobile_1mm[10]) ($mobile_1mm[11])                    ($mobile_1mm[12]) ($mobile_1mm[13]) ($mobile_1mm[14]) ($mobile_1mm[15]) $mobileC;                                setKeyframe -at "translate" -t $frame $mobileC;                setKeyframe -at "rotate" -t $frame $mobileC;                                        $frame = $frame+1;            }        }    }    checkBox -e -v 0 UseOriginalBonesButton;}