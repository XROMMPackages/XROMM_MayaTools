/* setpaths2 
    GUI to allow user to add and remove paths to the script path
    The gui opens/reads or creates the Maya.env file and then rewrites 
    with added or removed paths chosen by the user.
    
    requires fileread.mel
    
    User is not permitted to remove Maya default paths
    
    Currently only tested on Windows
    Written by David Baier 7/31/2012 
    7/29/2016 - updated to use xrmFileDlg instead of fileDialog. D. Baier
    3/7/2019 - renamed setpath to setpaths2 accomodates python paths
*/
global proc setpaths2()
{

	// Make the window
	if (`window -exists setpathWindow` == true) deleteUI setpathWindow;  
	
	int $height = 400;
	int $width = 400;
	
	string $mainWindow = `window -title "Set Path" -maximizeButton false -minimizeButton true
	-sizeable true -resizeToFitChildren false setpathWindow`;
	
	frameLayout -label "Current PATHS" -height $height -width $width -mw 5 -mh 5 spthFL1;
	columnLayout -co "left" 10 -rs 5 spthCL1;
		scrollLayout -width ($width - 20) -h 315 spthSL1;
			text "User-defined MAYA_SCRIPT_PATHS";
			textScrollList -numberOfRows 4 -width ($width + 150)
				-allowMultiSelection 1 -showIndexedItem 1 
				spthTSL1;
			text "User-defined PYTHONPATHS";
			textScrollList -numberOfRows 4 -width ($width + 150)
				-allowMultiSelection 1 -showIndexedItem 1 spthTSL3;
			text "default MAYA_SCRIPT_PATHS";
			textScrollList -numberOfRows 4 -width ($width + 150)
				-allowMultiSelection 1 -showIndexedItem 1 spthTSL2;		
			text "default PYTHONPATHS";
			textScrollList -numberOfRows 4 -width ($width + 150)
				-allowMultiSelection 1 -showIndexedItem 1 spthTSL4;
		setParent ..;
		rowLayout -nc 2 -cw2 ($width/4+40) ($width/4*3-40)  spthRL1;
			checkBox -label "include subfolders" -value 0 subfolderCheckBox;
			button -label "add path to both MAYA and PYTHON" -w ($width/4*3-60) 
			-c "spthAddBothCmd(1)" spthAddBothBtn;
		setParent ..;
		rowColumnLayout -nc 2 -rs 5 5 -cw 1 ($width/2-10) -cw 2 ($width/2-10);
			button -label "add MAYA_SCRIPT_PATH" -c "spthAddBothCmd(2)" addmspButton;
			button -label "add PYTHONPATH" -c "spthAddBothCmd(3)" addppButton;
			button -label "remove selected  MAYA_SCRIPT_PATH(s)" -c removeMSPath removepathButton; 
			button -label "remove selected  PYTHONPATH(s)" -c removePPath allScriptPathButtons;
			text " ";
		setParent ..; 
	setParent ..;
	setParent ..;
	showWindow $mainWindow;
	window -e -width $width -height $height $mainWindow;
	spthPopulateCmd;
}
global proc spthPopulateCmd()
{
	// get all locations that maya is currently looking for scripts
	string $spacer; if (`about -win`== 1){$spacer = ";";}else{$spacer = ":";};
	string $curmsp = `getenv "MAYA_SCRIPT_PATH"`;
	string $msp[] = stringToStringArray($curmsp,$spacer);
	string $usermsp[] = `getMayaEnvScriptPaths`;
	for ($i = 0;$i<size($usermsp);$i++){$usermsp[$i] = fromNativePath($usermsp[$i]);}
	string $mayamsp[] = stringArrayRemove($usermsp,$msp);
	
	string $curpp = `getenv "PYTHONPATH"`;
	string $pp[] = stringToStringArray($curpp,$spacer); 
	string $userpp[] = `getMayaEnvPythonPaths`;
	for ($i = 0;$i<size($userpp);$i++){$userpp[$i] = fromNativePath($userpp[$i]);}
	string $mayapp[] = stringArrayRemove($userpp,$pp);
	for($m in $usermsp)
		{textScrollList -e -append $m spthTSL1;}
	for($m in $mayamsp)
		{textScrollList -e -append $m spthTSL2;}
	for($p in $userpp)
		{textScrollList -e -append $p spthTSL3;}
	for($p in $mayapp)
		{textScrollList -e -append $p spthTSL4;}
}
proc spthWriteNewEnv(string $newEnvStr,string $spacer,string $lineHeader)
{	
	// read env file
	string $mayaEnv = `about -environmentFile`;
	string $mayaEnvLines[] = `fileread($mayaEnv)`;
	int $match = 0;

	for ($i=0;$i<size($mayaEnvLines);$i++) 
	{
		// if the current line contains MAYA_SCRIPT_PATH 
		if (`gmatch $mayaEnvLines[$i] ($lineHeader+"*")`)
			{$mayaEnvLines[$i] = $newEnvStr; $match = 1;}
	}
	
	// if there are no current MAYA_SCRIPT_PATH lines in env file, create one
	if ($match == 0)
		{$mayaEnvLines[size($mayaEnvLines)] = $newEnvStr;}
	
	// overwrite maya.env file
	$fileId = `fopen $mayaEnv "w"`;
	for($i=0;$i<size($mayaEnvLines)-1;$i++)
		{fprint $fileId ($mayaEnvLines[$i]+"\n");}   
	fprint $fileId ($mayaEnvLines[size($mayaEnvLines)-1]);
	fclose $fileId;
}
proc spthUpdateList(string $newPathArr[],string $tsl)
{
	// Now append the display list
	textScrollList -e -ra $tsl;
	for($p in $newPathArr)
	{
		$p = fromNativePath($p);
		textScrollList -e -append $p $tsl;
	}       
}
