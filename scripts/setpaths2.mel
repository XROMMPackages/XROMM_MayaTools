global proc spthAddBothCmd(int $int)
{
	string $spacer; if (`about -win`== 1){$spacer = ";";}else{$spacer = ":";};     
	// Get the users input for new path directory(ies)
	string $newPathArr[] = xrmFileDlg("Choose new path", 2, "", 1,"");
	if(`filetest -d $newPathArr[0]`)
	{	// get subfolders if needed
        if (`checkBox -q -v subfolderCheckBox`)
		{
			string $insideFolder[] = `getFileList -folder ($newPathArr[0]+"\\") -filespec "*."`;
			for ($a in $insideFolder)
				{$newPathArr[(size($newPathArr))] = ($newPathArr[0]+"\\" + $a);}
		}
	}
	if($int == 1)
		{newMspDir($newPathArr,$spacer); newPpDir($newPathArr,$spacer);}
	else if($int == 2)
		{newMspDir($newPathArr,$spacer);}
	else if($int == 3)
		{newPpDir($newPathArr,$spacer);}
}
global proc newMspDir(string $newPathArr[], string $spacer)
{ 
	// add new paths to existing paths
	string $msp[] = `getMayaEnvScriptPaths`;	
	appendStringArray($newPathArr, $msp, (size($msp)));
	for ($i = 0;$i<size($newPathArr);$i++){$newPathArr[$i] = toNativePath($newPathArr[$i]);}
	
	// elimate if already exists
	$newPathArr = `stringArrayRemoveDuplicates($newPathArr)`;	
	
	// create a string of new paths
	string $newPathStr = stringArrayToString ($newPathArr, $spacer);
	string $newEnvStr = ("MAYA_SCRIPT_PATH = " + $newPathStr);
	 
	spthWriteNewEnv($newEnvStr,$spacer,"MAYA_SCRIPT_PATH");
	
	// This added the new path(s) to the File - but the actual environment 
	// variable will not update until maya is restarted.
	// So we'll add the path to the current session
	string $curPathStr = `getenv "MAYA_SCRIPT_PATH"`;
	putenv "MAYA_SCRIPT_PATH" ($curPathStr + $spacer + $newPathStr);
	rehash;
	
	// Now append the display list and source top level folder
	string $preUpdate[] = `textScrollList -q -ai "spthTSL1"`;
	spthUpdateList($newPathArr,"spthTSL1");
	string $postUpdate[] = `textScrollList -q -ai "spthTSL1"`;
	if($postUpdate[0]!=$preUpdate[0])
		{confirmDialog -title "Restart required"
		-message "Must restart maya for new folder to take precedence";}
}
global proc newPpDir(string $newPathArr[], string $spacer)
{    
	// add new paths to existing paths
	string $msp[] = `getMayaEnvPythonPaths`;
	appendStringArray($newPathArr, $msp, (size($msp)));
	for ($i = 0;$i<size($newPathArr);$i++){$newPathArr[$i] = toNativePath($newPathArr[$i]);}
	
	// elimate if already exists
	$newPathArr = `stringArrayRemoveDuplicates($newPathArr)`; 
	 
	// create a string of new paths
	string $newPathStr = stringArrayToString ($newPathArr, $spacer);
	string $newEnvStr = ("PYTHONPATH = " + $newPathStr);
	
	spthWriteNewEnv($newEnvStr,$spacer,"PYTHONPATH");
	
	// This added the new path(s) to the File - but the actual environment variable will not update
	// until maya is restarted. Now we'll add the path to the current session (this
	// doesn't seem to work. We'll try using the python command below
	string $curPathStr = `getenv "PYTHONPATH"`;
	putenv "PYTHONPATH" ($curPathStr + $spacer + $newPathStr);
	
	// Now append the display list
	spthUpdateList($newPathArr,"spthTSL3");
}
global proc removeMSPath()
{
    // paths to be removed
    string $pathToBeRemoved[] = `textScrollList -q -si spthTSL1`; 
    if (size($pathToBeRemoved)>0)
    {
    	// convert forward slash to backward slash
    	for ($i = 0; $i<(size($pathToBeRemoved)); $i++)
    		{$pathToBeRemoved[$i] = toNativePath($pathToBeRemoved[$i]);};
    	
       string $origEnvArr[] = `getMayaEnvScriptPaths`;   
       string $spacer; if (`about -win`== 1){$spacer = ";";}else{$spacer = ":";};

        // make new array removing paths
        string $newPathArr[] = stringArrayRemove($pathToBeRemoved, $origEnvArr);
        // new string for maya script path
        string $newEnvStr;
        if(size($newPathArr)>0)
		{
			$newEnvStr = stringArrayToString($newPathArr, $spacer);
			$newEnvStr = ("MAYA_SCRIPT_PATH = " + $newEnvStr);
		}
        else
		{$newEnvstr = ("");}
	
		spthWriteNewEnv($newEnvStr,$spacer,"MAYA_SCRIPT_PATH");
		
		// This added the new path(s) to the File - but the actual environment variable will not update
		// until maya is restarted. Now we'll add the path to the current session
		string $curPathStr = `getenv "MAYA_SCRIPT_PATH"`;
		string $curPaths[] = stringToStringArray($curPathStr,$spacer);
		string $newPaths[] = stringArrayRemove($pathToBeRemoved,$curPaths);
		string $newStr = stringArrayToString($newPaths,$spacer);
		putenv "MAYA_SCRIPT_PATH" ($newStr);
		rehash;
		
		// Now append the display list
		string $preUpdate[] = `textScrollList -q -ai "spthTSL1"`;
		spthUpdateList($newPathArr,"spthTSL1");
		string $postUpdate[] = `textScrollList -q -ai "spthTSL1"`;
		if($postUpdate[0]!=$preUpdate[0])
			{confirmDialog -title "Restart required"
			-message "Must restart maya for new folder to take precedence";}
	}
}
global proc removePPath()
{
    string $var = "PYTHONPATH";
    // paths to be removed
    string $pathToBeRemoved[] = `textScrollList -q -si spthTSL3`; 
    if (size($pathToBeRemoved)>0)
    {
    	// convert forward slash to backward slash
    	for ($i = 0; $i<(size($pathToBeRemoved)); $i++)
    		{$pathToBeRemoved[$i] = toNativePath($pathToBeRemoved[$i]);};
    	
       string $origEnvArr[] = `getMayaEnvPythonPaths`;   
       string $spacer; if (`about -win`== 1){$spacer = ";";}else{$spacer = ":";};

        // make new array removing paths
        string $newPathArr[] = stringArrayRemove($pathToBeRemoved, $origEnvArr);
        // new string for maya script path
        string $newEnvStr;
        if(size($newPathArr)>0)
		{
			$newEnvStr = stringArrayToString($newPathArr, $spacer);
			$newEnvStr = ($var + " = " + $newEnvStr);
		}
        else
		{$newEnvstr = ("");}
     
	  	spthWriteNewEnv($newEnvStr,$spacer,"PYTHONPATH");
		
		// This added the new path(s) to the File - but the actual environment variable will not update
		// until maya is restarted. Now we'll add the path to the current session
		string $curPathStr = `getenv $var`;
		string $curPaths[] = stringToStringArray($curPathStr,$spacer);
		string $newPaths[] = stringArrayRemove($pathToBeRemoved,$curPaths);
		string $newStr = stringArrayToString($newPaths,$spacer);
		putenv $var ($newStr);
		rehash;
		
		// Now append the display list
		spthUpdateList($newPathArr,"spthTSL3");
	}
}
