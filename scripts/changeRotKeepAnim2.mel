/*  global proc changeRotKeepAnim2()    Input:  $objs - input objects.            $rotOrder - string representing the new rotation order (e.g. "zxy")               create a new object with the input rotation order, then apply the rotion   matrix of the orignal and set keyframes for each rotation.   Problem - can result in non-intuitive euler angles because matrix angle              reconstructions don't enforce a continuous angle rule   Written by David Baier*/     global proc changeRotKeepAnim2(string $objs, string $rotOrder){         // if objs is empty use the selected item        if (size($objs) == 0){string $objs[] = `ls -selection`;}     // only if we still have something selected	if (size($objs) > 0)	{	    // make sure autokey is off!!!	    if (`autoKeyframe -q -state` == 1){autoKeyframe -state 0;}	    for ($obj in $objs)	    {            //set start and end frames            int $frame = `findKeyframe -hi both -which first $obj`;            int $lastframe = `findKeyframe -hi both -which last $obj`;            int $previousframe = $lastframe+1;                        // create new object and change its rotation order based on user input            string $newObjStr = ($obj+$rotOrder);            $newObj = `spaceLocator -n $newObjStr`;            xform -roo $rotOrder $newObj;                        // create float array to store tform matrix            float $tform[];            currentTime -update 1 -edit $frame;            // loop through frames            for ($i = $frame; $i<= $lastframe; $i++)            {                currentTime -update 1 -edit $i;                                // apply transforms                $tform = `xform -ws -q -m $obj`;                xform -m ($tform[0]) ($tform[1]) ($tform[2]) ($tform[3])                         ($tform[4]) ($tform[5]) ($tform[6]) ($tform[7])                         ($tform[8]) ($tform[9]) ($tform[10]) ($tform[11])                         ($tform[12]) ($tform[13]) ($tform[14]) ($tform[15]) $newObj;                                          // set keys                            setKeyframe -at "rotate" $newObj;                 setKeyframe -at "translate" $newObj;            }            print ("done. \n");        }    }}