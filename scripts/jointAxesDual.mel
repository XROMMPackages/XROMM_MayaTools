/* global proc jointAxesDual() 	    GUI for setting up joint coordinate system        User firt estabilishes the zero pose of the proximal and distal elements    Places the joint pivot and orientation.    When the bone models have animation, running jointAxesDual calculates the relative    motion of the axes	Written by David Baier 4/1/09*/global proc jointAxesDual(){	if (`window -exists jointAxesWindow` == true) deleteUI jointAxesWindow;  	int $height = 500;	int $width = 550;	string $mainWindow = `window		-title "Anatomical Joint Axes"		-menuBar true		-maximizeButton false		-minimizeButton true		-sizeable true		-resizeToFitChildren false		jointAxesWindow`;			frameLayout -label "Anatomical joint axes"		-height $height		-width $width		-mw 5		-mh 5;			columnLayout;		menu -label "File";	menuItem -label "Reset" -command cRec resetButton;	menuItem -label "Close" -command "deleteUI jointAxesWindow" closeButton;	columnLayout;		text "Step 1: Select the proximal and distal objects";	textFieldButtonGrp		-label "Proximal Object" 		-text "Select proximal element and click Insert Selection" 		-buttonLabel "Insert Selection" 		-buttonCommand proxSelectB 	proxFieldGroup;	textFieldButtonGrp		-label "Distal Object" 		-text "Select distal element and click Insert Selection" 		-buttonLabel "Insert Selection" 		-buttonCommand distSelectB	distFieldGroup;    	text " ";	text "Step 2: Type a new axes name or select an existing one and click Insert Selection";    textFieldButtonGrp        -label "Axes Name"        -text  "Type Axes Name or Select existing axes"		-buttonLabel "Insert Selection" 		-buttonCommand axesSelectB		-cc enableCheckB		axesFieldGroup;		    floatFieldGrp -nf 1 -label "Scale" -extraLabel "cm" -cw 1 140         -cl3 "right" "right" "right" -value1 5.0 jacoordScaleUI;    radioButtonGrp -nrb 2 -label "Style" -labelArray2 "Hemi" "Full"         -cw 1 140 -cl3 "right" "right" "right" jastyleUI;    radioButtonGrp -e -sl 1 jastyleUI;    radioButtonGrp -nrb 2 -label "Output" -labelArray2 "Single Object" "Separate axes"         -cw 1 140 -cl3 "right" "right" "right" jasingleObjectUI;    radioButtonGrp -e -sl 1 jasingleObjectUI;     text " ";            	text "Note: If using existing axes, skip to step 7. To adjust existing axes, first delete the";	text "         axes on the proximal bone (Prox suffix),and follow all steps except step 4.";	setParent..;		text " ";	text "Step 3: Place and orient the bones in the position that you want to be 0 0 0 translation 0 0 0 rotation ";	text "Step 4: Create Anatomical Axes either With or Without Locators";		button	-label "Create Axes with Locators" -enable 0 -w ($width - 40) -command createAxesB createAxesBButton;	button  -label "Create Axes without Locators"  -enable 0 -w ($width -40) - command createAxesNL createAxesNLButton;	text " ";		text "Step 5: Use the two locators, if present, to position and orient the blue axis as the axis of primary motion.";	text "Otherwise, move the axis into position with the move and rotation tools.";	text "Step 6: If using locators, select the axis and use the rotateZ to orient the red/green axes";	text "Step 7: Click Set Joint Axes";	text " ";	button	-label "Set Joint Axes" -enable 0 -w ($width - 40) -command setAxesB setAxesBButton;	button	-label "Close" -w ($width - 40) closeButton;	button -edit -command "deleteUI jointAxesWindow" closeButton;	showWindow $mainWindow;	window -e -width $width -height $height $mainWindow;}global proc proxSelectB(){	string $objs[] = `ls -sl`;	textFieldButtonGrp -e -text $objs[0] proxFieldGroup;}global proc distSelectB(){	string $objs[] = `ls -sl`;	textFieldButtonGrp -e -text $objs[0] distFieldGroup;}global proc axesSelectB(){	string $objs[] = `ls -sl`;	textFieldButtonGrp -e -text $objs[0] axesFieldGroup;	enableCheckB;}global proc enableCheckB(){	string $prox = `textFieldButtonGrp -q -text proxFieldGroup`;	string $dist = `textFieldButtonGrp -q -text distFieldGroup`;	string $axes = `textFieldGrp -q -text axesFieldGroup`;		if (`objExists $prox` && `objExists $dist`)	{		if (!`objExists $axes`)		{			button -edit -enable 1 createAxesBButton;			button -edit -enable 1 createAxesNLButton;			button -edit -enable 0 setAxesBButton;			print "it works\n";		}		else		{			button -edit -enable 0 createAxesBButton;			button -edit -enable 0 createAxesNLButton;			button -edit -enable 1 setAxesBButton;		}	}}global proc createAxesB(){	string $prox = `textFieldButtonGrp -q -text proxFieldGroup`;	string $dist = `textFieldButtonGrp -q -text distFieldGroup`;	string $axes = `textFieldGrp -q -text axesFieldGroup`;		// get coordinate to place axes near the bone	//	vector $vtx = `xform -ws -q -t ($prox+".vtx[0]");	vector $vtx = <<0,0,0>>;	if (!`objExists $axes`)	{		//createGiantLocator($axes);		float $size = `floatFieldGrp -q -value1 jacoordScaleUI`;		int $style = `radioButtonGrp -q jastyleUI`;		int $singleObject = `radioButtonGrp -q jasingleObjectUI`;		axesCreate($axes, $size, $style, $singleObject);				// flip rotation order for ease of positioning		// this will not affect outcome because data is calculated from matrices		xform -roo zyx $axes;				// add attributes to store proximal distal bones		// and their initial position matrices		addAttr -ln "proximalBone" -sn "prox" -dt "string" -keyable true $axes;		addAttr -ln "distalBone" -sn "dist" -dt "string" -keyable true $axes;				string $posZ = ($axes + "positiveZ");		string $negZ = ($axes + "negativeZ");		spaceLocator -n $posZ;		move 0 0 10;		spaceLocator -n $negZ;		move 0 0 -10;				pointConstraint $posZ $negZ $axes;		aimConstraint   -offset 0 0 0 						-weight 1 						-aimVector 0 0 1 						-upVector 0 1 0 						-worldUpType "none"						-skip z $posZ $axes;		// reposition relative to the first vertex on the proximal object		move ($vtx.x + 5) ($vtx.y) ($vtx.z) $posZ;		move ($vtx.x - 5) ($vtx.y) ($vtx.z) $negZ;				button -edit -enable 0 createAxesBButton;		button -edit -enable 0 createAxesNLButton;		button -edit -enable 1 setAxesBButton;	}}global proc createAxesNL(){string $prox = `textFieldButtonGrp -q -text proxFieldGroup`;	string $dist = `textFieldButtonGrp -q -text distFieldGroup`;	string $axes = `textFieldGrp -q -text axesFieldGroup`;		// get coordinate to place axes near the bone	//	vector $vtx = `xform -ws -q -t ($prox+".vtx[0]");	vector $vtx = <<0,0,0>>;	if (!`objExists $axes`)	{		float $size = `floatFieldGrp -q -value1 jacoordScaleUI`;		int $style = `radioButtonGrp -q jastyleUI`;		int $singleObject = `radioButtonGrp -q jasingleObjectUI`;		axesCreate($axes, $size, $style, $singleObject);				// flip rotation order for ease of positioning		// this will not affect outcome because data is calculated from matrices		xform -roo zyx $axes;				// add attributes to store proximal distal bones		// and their initial position matrices		addAttr -ln "proximalBone" -sn "prox" -dt "string" -keyable true $axes;		addAttr -ln "distalBone" -sn "dist" -dt "string" -keyable true $axes;								button -edit -enable 0 createAxesBButton;		button -edit -enable 0 createAxesNLButton;		button -edit -enable 1 setAxesBButton;	}}global proc setAxesB(){    string $prox = `textFieldButtonGrp -q -text proxFieldGroup`;	string $dist = `textFieldButtonGrp -q -text distFieldGroup`;    string $axes = `textFieldGrp -q -text axesFieldGroup`;	string $makeProxAxes = "Yes";    	// in case the user accidentally selected the prox element	if (`endString $axes 4` == "Prox")		{$axes = `substring $axes 1 (size($axes)-4)`;}		string $axesP = ($axes+"Prox");		string $posZ = ($axes + "positiveZ");	string $negZ = ($axes + "negativeZ");		// the axis exists but is not child of distal bone	if (!isParentOf($dist, $axes))	{		parent $axes $dist;		if (`objExists $posZ`){ parent $posZ $dist;}		if (`objExists $negZ`){ parent $negZ $dist;}	}		// the proximal axis doesn't exist    if (!`objExists $axesP`)	{		$makeProxAxes = `confirmDialog -t "Setting Proximal Bone Axes"			-m "You are about to set the neutral position of\nyour joint coordinate system.\n Are your bones in the position that \nyou want to describe as 0 0 0 translation and 0 0 0 rotation"			-button "Yes" -button "No" -defaultButton "Yes"			-cancelButton "No" -dismissString "No"`;		if ($makeProxAxes == "Yes")		{			duplicate -rc -rr -n $axesP $axes;			// if axes had children other than the shape node ([0] position)			// delete them. We just want a copy of the axis parented to the 			// proximal bone			string $constraints2beDeleted[] = `listRelatives -c $axesP`;			if (size($constraints2beDeleted) > 1)			{				delete $constraints2beDeleted[1];				delete $constraints2beDeleted[2];			}			parent $axesP $prox;		}	}		if ($makeProxAxes == "Yes")	{		// proximal exists but isn't parented to proximal bone		if (!isParentOf($prox, $axesP))		{			parent $axesP $prox;		}				getAxesdataB($axesP, $axes);	}	else	{		confirmDialog -t "Aborting" 			-m "Set the bones in their neutral position and click set axes again"			-button "OK" -defaultButton "OK";	}}global proc getAxesdataB(string $axesP, string $axesD){		string $prox = `textFieldButtonGrp -q -text proxFieldGroup`;	string $dist = `textFieldButtonGrp -q -text distFieldGroup`;    string $axes = `textFieldGrp -q -text axesFieldGroup`;	string $transformList[] = `ls -tr`;	int $globalKeys = 0;		// first try to get animation from the objects heirarchy	int $frame = `findKeyframe -hi both -which first $prox $dist` ;	int $lastframe = `findKeyframe -hi both -which last $prox $dist`;		// if that doesn't work, see if there is any animation in the scene	if ($frame-$lastframe == 0)		{			$frame = `findKeyframe -hi both -which first $transformList` ;			$lastframe = `findKeyframe -hi both -which last $transformList`;			$globalKeys = 1;		}	// Nothing happens if no frames	if ($frame-$lastframe == 0)		{print "No animation in scene";}	int $previousframe = $lastframe+1;		if ($frame <= 0){$frame = 1;}	currentTime -update 1 -edit $frame;		string $output = $axesD + "data";	spaceLocator -n $output;	string $actualName[] = `ls -sl`;	$output = $actualName[0];			 progressWindow		 -title "Calculating Joint Axes"		 -min $frame		 -max $lastframe		 -progress $frame		 -status ("Processing frame: "+$frame)		 -isInterruptable true;			//loop through time		while ($frame <= $lastframe)		{				//get the worldspace xform of the current object				$oldMatrix = `xform -ws -q -m $axesD`;				matrix $axesDurChild[4][4] = mmTotm(`xform -ws -q -m $axesD`);				matrix $axesDurParent[4][4] = mmTotm(`xform -ws -q -m $axesP`);				matrix $outchild[4][4] = relativeTm($axesDurParent, $axesDurChild);					   // apply the new rotation matrix to the oldMatrix				$newMatrix = tmTomm($outchild);								xform -m    ($newMatrix[0]) ($newMatrix[1]) ($newMatrix[2]) ($newMatrix[3])							($newMatrix[4]) ($newMatrix[5]) ($newMatrix[6]) ($newMatrix[7])							($newMatrix[8]) ($newMatrix[9]) ($newMatrix[10]) ($newMatrix[11])							($newMatrix[12]) ($newMatrix[13]) ($newMatrix[14]) ($newMatrix[15]) $output;											// ideally we should have a continuous angle check here				setKeyframe -at "rotate" $output;				setKeyframe -at "translate" $output;								// Check if the dialog has been cancelled				if ( `progressWindow -query -isCancelled` ) break;												if ($globalKeys == 0)				{$frame = `findKeyframe -hi both -which next $axesD`;}				else				{$frame = `findKeyframe -hi both -which next $transformList`;}								if (($frame-$previousframe) == 0){break;}				$previousframe = $frame;								progressWindow -edit				 -progress $frame				 -status ("Processing frame: "+$frame);								currentTime -update 1 -edit $frame;		}		progressWindow -endProgress;}